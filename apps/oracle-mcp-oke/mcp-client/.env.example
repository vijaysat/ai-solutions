# Copy to .env and fill in values for local development.

# =========================================================
# REQUIRED (mcp-client/oracle_agent.py runtime)
# =========================================================
MCP_URL=http://127.0.0.1:8080/mcp/
ENVIRONMENT=PRD

# OCI Generative AI setup
COMPARTMENT_ID=ocid1.compartment.oc1....
MODEL_ID=cohere.command-a-03-2025
SERVICE_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
PROVIDER=cohere

# OCI auth profile used by mcp-client/auth/oci_auth.py
# AUTH_TYPE=API_KEY
# AUTH_PROFILE=DEFAULT

# Object Storage target used for audio upload + speech flows
OCI_NAMESPACE=your-namespace
SPEECH_BUCKET=audio-bucket

# =========================================================
# OPTIONAL (runtime tuning)
# =========================================================
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096
# OCI_CONFIG_FILE=/Users/<your-user>/.oci/config
# OCI_REGION=us-chicago-1
# Optional explicit transport override: http | streamable_http | sse | stdio | websocket
# MCP_TRANSPORT=http
# SPEECH_COMPARTMENT_OCID=ocid1.compartment.oc1....
SPEECH_MODEL_TYPE=WHISPER_LARGE_V3T
SPEECH_LANGUAGE_CODE=auto
SPEECH_DIARIZATION_ENABLED=true
SPEECH_JOB_NAME=Transcription-Job
SPEECH_OUTPUT_PREFIX=transcriptions
SPEECH_INPUT_PREFIX=uploads/

# Optional MCP OAuth
MCP_AUTH_ENABLED=false
# MCP_AUTH_TOKEN_URL=https://<idcs-domain>/oauth2/v1/token
# MCP_AUTH_CLIENT_ID=<oauth-client-id>
# MCP_AUTH_CLIENT_SECRET=<oauth-client-secret>
# MCP_AUTH_SCOPE=https://genaisolutions.com/read
# MCP_AUTH_ACCESS_TOKEN=<access-token>

# Gradio
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
